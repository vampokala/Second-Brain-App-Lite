# Optional overrides — environment variables win over GUI-saved paths and keys.
# Copy to `.env` only if your toolchain loads dotenv for shell builds (optional).

# SECOND_BRAIN_VAULT_ROOT=/absolute/path/to/vault
# SECOND_BRAIN_RAW_DIR=/absolute/path/to/raw
# SECOND_BRAIN_WIKI_DIR=/absolute/path/to/wiki
# SECOND_BRAIN_SCHEMA_DIR=/absolute/path/to/schema

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# COMPATIBLE_API_KEY=
